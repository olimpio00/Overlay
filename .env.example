# Variáveis de ambiente suportadas pelo IROS.
# Quando presentes, sobrescrevem o que está em config.json em runtime
# (sem persistir de volta no arquivo).

# Token usado pelas rotas /api/v1/*. Gere um valor longo:
#   openssl rand -hex 32
IROS_API_TOKEN=

# Domínio público que o front usa pra montar a URL do WebSocket.
# Localmente:        localhost:8080
# Render (exemplo):  iros-meu.onrender.com
IROS_SERVER_DOMAIN=

# Endereço de bind do servidor HTTP.
# Local:             127.0.0.1 ou localhost
# Container/Cloud:   0.0.0.0  (já é o default no Dockerfile)
IROS_HTTP_ADDRESS=

# Use wss:// (true) ou ws:// (false) na URL do WebSocket gerada pro front.
# Render/Fly fornecem HTTPS automático, então em produção: true
IROS_USE_WSS=

# Porta HTTP. Render injeta automaticamente $PORT, então normalmente
# você NÃO precisa setar isso manualmente em produção.
PORT=
